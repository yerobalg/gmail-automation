# Gmail credentials
# GMAIL_APP_PASSWORD is the 16-character App Password from
# https://myaccount.google.com/apppasswords (2-Step Verification required).
GMAIL_USER=sender@gmail.com
GMAIL_APP_PASSWORD=xxxxxxxxxxx

# Shown in the From header and email signature
SENDER_NAME=Laksono

# Subject line
EMAIL_SUBJECT=Invoice

# Where to look for attachment folders
ATTACHMENTS_ROOT=./attachments

# Chunking limits
MAX_ATTACHMENTS_PER_EMAIL=5
MAX_SIZE_MB=15
