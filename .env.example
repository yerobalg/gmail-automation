# Sender credentials.
# For Gmail / Google Workspace: SMTP_PASSWORD is the 16-character App Password
# from https://myaccount.google.com/apppasswords (2-Step Verification required).
# For other providers, use your mailbox password.
SMTP_USER=sender@example.com
SMTP_PASSWORD=xxxxxxxxxxx

# SMTP server. Defaults shown are for Gmail / Google Workspace.
# Use port 465 for implicit TLS, 587 for STARTTLS.
# Examples:
#   Gmail / Workspace:  smtp.gmail.com:465
#   Microsoft 365:      smtp.office365.com:587
#   Zoho:               smtp.zoho.com:465
#   Zimbra / custom:    ask your IT
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465

# Shown in the From header and email signature
SENDER_NAME=Laksono

# Subject line
EMAIL_SUBJECT=Invoice

# Where to look for attachment folders
ATTACHMENTS_ROOT=./attachments

# Chunking limits
MAX_ATTACHMENTS_PER_EMAIL=5
MAX_SIZE_MB=15
